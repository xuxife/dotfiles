{
    "title": "right_control+page up/down -> volume up/down",
    "rules":
    [
        {
            "description": "change right_control+page up/down to control volume",
            "manipulators":
            [
                {
                    "from":
                    {
                        "key_code": "page_up"
                    },                    "to":
                    [
                        {
                            "key_code": "display_brightness_increment"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "from":
                    {
                        "key_code": "page_down"
                    },                    "to":
                    [
                        {
                            "key_code": "display_brightness_decrement"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "from":
                    {
                        "key_code": "page_down",
                        "modifiers":
                        {
                            "mandatory":
                            [
                                "control"
                            ]
                        }
                    },
                    "to":
                    [
                        {
                            "key_code": "volume_decrement"
                        }
                    ],
                    "type": "basic"
                },                {
                    "from":
                    {
                        "key_code": "page_up",
                        "modifiers":
                        {
                            "mandatory":
                            [
                                "control"
                            ]
                        }
                    },
                    "to":
                    [
                        {
                            "key_code": "volume_increment"
                        }
                    ],
                    "type": "basic"
                }
            ]
        }
    ]
}
